#!/bin/bash
pip3 install pyyaml psutil pyxdg playwright openai || true
python3 -m playwright install chromium || true
chmod +x /usr/lib/jiopc-agent/jiopc_agent.py || true
chmod +x /usr/bin/jiopc-agent || true
mkdir -p /home/user/.local/share/jiopc/agent || true
chown -R user:user /home/user/.local/share/jiopc || true
